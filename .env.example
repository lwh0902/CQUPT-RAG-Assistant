ZHIPU_API_KEY=your_zhipu_api_key
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
JWT_SECRET_KEY=change-me-to-a-random-string

MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=cqupt_rag
# Keep SQL statements out of production logs. Enable only while debugging locally.
SQL_ECHO=false

# Optional: set this when you want to rebuild the vector index from a PDF file.
PDF_PATH=student_manual.pdf

# Optional: backend runtime settings.
API_HOST=0.0.0.0
API_PORT=8012
API_RELOAD=true

# Application logs are printed to stdout and retained as daily rotating files.
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_BACKUP_DAYS=14

# Optional: CORS allowed origins (comma-separated).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: frontend connection settings.
API_BASE_URL=http://127.0.0.1:8012
# WS_BASE_URL=ws://127.0.0.1:8012

# Optional: real web search. Keep disabled until a Tavily key is configured.
WEB_SEARCH_PROVIDER=disabled
TAVILY_API_KEY=
WEB_SEARCH_TIMEOUT_SECONDS=8

# Local retrieval evidence gate. Tune only from human-reviewed evaluation data.
RETRIEVAL_VECTOR_SUPPORTED_THRESHOLD=0.52
RETRIEVAL_VECTOR_OUT_OF_SCOPE_THRESHOLD=0.30
RETRIEVAL_KEYWORD_COVERAGE_THRESHOLD=0.50

# Optional: MCP-first web-search tool over Streamable HTTP.
MCP_WEB_SEARCH_URL=
MCP_WEB_SEARCH_TOOL_NAME=web_search
MCP_WEB_SEARCH_AUTH_TOKEN=
