# === REQUIRED secrets (never commit real values) ===
# Zhipu is only used for embedding-2. All chat/rewrite/summary use DeepSeek.
ZHIPU_API_KEY=your_zhipu_api_key
EMBEDDING_MODEL=embedding-2
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash

# Generate with: openssl rand -hex 32
# Must be >= 32 chars and not a placeholder like change-me.
JWT_SECRET_KEY=replace-with-openssl-rand-hex-32-output
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Cookie flags. Enable Secure cookies behind HTTPS in production.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

MYSQL_USER=root
# Use a strong password in production. Weak defaults like 123456 are rejected
# unless ALLOW_INSECURE_DB_PASSWORD=true (local development only).
MYSQL_PASSWORD=replace-with-a-strong-password
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=cqupt_rag
ALLOW_INSECURE_DB_PASSWORD=false
# Keep SQL statements out of production logs. Enable only while debugging locally.
SQL_ECHO=false

# Optional: set this when you want to rebuild the vector index from a PDF file.
PDF_PATH=student_manual.pdf

# Optional: backend runtime settings.
API_HOST=0.0.0.0
API_PORT=8012
# Disable reload in production.
API_RELOAD=false

# Application logs are printed to stdout and retained as daily rotating files.
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_BACKUP_DAYS=14

# Optional: CORS allowed origins (comma-separated). Required when frontend is on another origin.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: frontend connection settings.
API_BASE_URL=http://127.0.0.1:8012

# Optional: real web search. Keep disabled until a Tavily key is configured.
WEB_SEARCH_PROVIDER=disabled
TAVILY_API_KEY=
WEB_SEARCH_TIMEOUT_SECONDS=8

# Local retrieval evidence gate. Tune only from human-reviewed evaluation data.
RETRIEVAL_VECTOR_SUPPORTED_THRESHOLD=0.52
RETRIEVAL_VECTOR_OUT_OF_SCOPE_THRESHOLD=0.30
RETRIEVAL_KEYWORD_COVERAGE_THRESHOLD=0.50
# Min vector score for the BM25+coverage support path (calibrated 2026-07-22).
RETRIEVAL_BM25_VECTOR_FLOOR=0.28

# Knowledge-path rewrite gate: auto=retrieve first then rewrite if weak; on=always; off=never.
REWRITE_MODE=auto
REWRITE_EXPANSION_WEIGHT=0.5

# Hybrid candidate pool (fusion) vs final evidence count returned to generation.
CANDIDATE_TOP_K=16
HYBRID_FUSION_TOP_K=12
# Final evidence pages injected into the prompt (page-level, after dedupe).
RETRIEVAL_TOP_K=4
# Hard char budget for the evidence block (~700 chars/page median).
CONTEXT_MAX_CHARS=4500

# Working memory (ChatGPT-style near window + single rolling overflow summary in MySQL).
# Near window keeps the last N rounds verbatim in chat messages.
SHORT_TERM_ROUNDS=6
# Max structured profile lines injected into the system prompt.
PROFILE_INJECT_K=5
# When history exceeds the near window, summarize older turns with the LLM and
# store ONE rolling summary per session on MySQL sessions.* (not the vector DB).
OVERFLOW_SUMMARY_ENABLED=true
OVERFLOW_SUMMARY_MAX_CHARS=300
SESSION_HISTORY_LOAD_LIMIT=80

# Optional: MCP-first web-search tool over Streamable HTTP.
MCP_WEB_SEARCH_URL=
MCP_WEB_SEARCH_TOOL_NAME=web_search
MCP_WEB_SEARCH_AUTH_TOKEN=

# Follow-up resolution: LLM rewrites deictic follow-ups into one clean standalone
# query (no scaffolding tokens); rule-based concatenation is the fallback.
FOLLOWUP_LLM_RESOLVE=true

# Profile memory write gate (P1).
# Regex path always on; LLM extract expands coverage with whitelist + confidence tiers.
MEMORY_LLM_EXTRACT_ENABLED=true
MEMORY_AUTO_CONFIRM_MIN_CONFIDENCE=0.90
MEMORY_PENDING_MIN_CONFIDENCE=0.70
MEMORY_CANDIDATE_TTL_HOURS=72
# Legacy Chroma session summary_window injection (MySQL overflow is preferred).
CHROMA_SESSION_SUMMARY_IN_PROMPT=false
